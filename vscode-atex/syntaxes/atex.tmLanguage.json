{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Atex",
	"patterns": [
		{
			"include": "#keywords"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.atex",
				"match": "@(chapter|section|subsection|eq|todo|figure|codeBlock|terminal|problem|list|li|url|em|def|code|m|note|ref|p)"
			}]
		}
	},
	"scopeName": "source.atex"
}